# ============================================================
# FilterIN — Template Environment Variables
# Salin file ini menjadi .env lalu isi nilainya
#   cp .env.example .env
# ============================================================

# --- MySQL Database ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=filterin_db

# --- Google Sheets (ID spreadsheet, bukan URL lengkap) ---
SPREADSHEET_UPLOAD=your_spreadsheet_id_here
SPREADSHEET_KENDALA=your_spreadsheet_id_here
SPREADSHEET_ODP=your_spreadsheet_id_here
SPREADSHEET_PSRE=your_spreadsheet_id_here
SPREADSHEET_KPI=your_spreadsheet_id_here

# --- Google Service Account ---
# Letakkan file credentials.json di folder backend/
# (minta file ini dari pemilik project, JANGAN di-commit ke git)
GOOGLE_CREDS_PATH=credentials.json

# --- Flask ---
FLASK_SECRET_KEY=ganti_dengan_string_random_panjang_minimal_32_karakter

# --- Cache & Lock (opsional, sudah ada default) ---
SHEET_CACHE_TTL=30
EDIT_LOCK_TTL_MINUTES=5
